# GoHighLevel inbound webhook URL — SERVER-ONLY (no NEXT_PUBLIC_ prefix, so the
# secret never reaches the client bundle). Set in Vercel for Preview + Production.
# The live Vercel env edit + deletion of the OLD public webhook var happen in 05-06;
# this file only documents the contract — it does not hold live values.
GHL_WEBHOOK_URL=

# Upstash Redis REST credentials — from the Vercel Marketplace "Upstash Redis"
# integration. They back the /api/lead rate limiter. OPTIONAL: when absent the
# route degrades gracefully to honeypot-only anti-spam (see 05-02), so a preview
# works before Upstash is provisioned.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google Search Console verification token — legitimately public (rendered into
# <head> metadata via app/layout.tsx), so the NEXT_PUBLIC_ prefix is correct here.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
